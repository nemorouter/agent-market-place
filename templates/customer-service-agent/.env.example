# ─────────────────────────────────────────────────────────────────────────────
# .env.example — filled in with Acme Inc as a concrete example.
# Copy to .env.local and replace the Acme values with your own.
# ─────────────────────────────────────────────────────────────────────────────

# ── Nemo Router (the brain — LLM + tools) ───────────────────────────────────
# Create this key in the Nemo dashboard. Give it a per-day BUDGET (your hard spend
# cap — Layer 4) and a rate limit. SERVER-SIDE ONLY: never expose it to the browser.
NEMOROUTER_API_KEY=sk-nemo-acme-xxxxxxxxxxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-3-small
GUARDRAILS=

# ── The agent ────────────────────────────────────────────────────────────────
AGENT_ID=acme-support
AGENT_NAME=Acme Support
SYSTEM_PROMPT=You are Acme's support assistant. Answer ONLY from the provided context. If it isn't covered, say so and point the user to https://acme.com/support. Keep answers to 2-4 sentences.
TOP_K=6

# ── Acme's OWN Supabase project (Acme creates it + pays for it) ──────────────
SUPABASE_URL=https://acme-xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-acme-service-role-key
SUPABASE_ANON_KEY=eyJ-acme-anon-key

# ── Knowledge sources (used by POST /api/ingest) ─────────────────────────────
DOCS_PATH=./docs
DOCS_BASE_URL=https://acme.com/docs
WEBSITE_URL=https://acme.com/docs
WEBSITE_MAX_PAGES=60

# ── Abuse protection (Layers 1-3; Layer 4 = the key budget set in Nemo) ──────
ALLOWED_ORIGINS=https://acme.com,https://*.acme.com,http://localhost:3000
RATE_LIMIT_PER_IP_PER_MIN=20
RATE_LIMIT_PER_SESSION_PER_MIN=10
RATE_LIMIT_PER_IP_PER_DAY=500
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=
REQUIRE_EMAIL=false

# ── Admin (gates POST /api/ingest) ───────────────────────────────────────────
ADMIN_TOKEN=replace-with-a-long-random-string
