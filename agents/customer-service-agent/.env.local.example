# ─── .env.local — LOCAL dev for Acme Inc ─────────────────────────────────────
# Copy to `.env.local` (gitignored) and fill the 4 ★ values, then: npm run dev
# Runs on http://localhost:3000 — Acme answers from its OWN Supabase KB.

CLOUD=local

# ★ Nemo Router (the brain). Create the key in the Nemo dashboard with a per-day
#   BUDGET + rate limit. SERVER-SIDE ONLY.
NEMOROUTER_API_KEY=sk-nemo-acme-local-xxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-005
GUARDRAILS=

# The agent
AGENT_ID=acme-support
AGENT_NAME=Acme Support
SYSTEM_PROMPT=You are Acme's support assistant. Answer ONLY from the provided context. If it isn't covered, say so and point the user to https://acme.com/support. Keep answers to 2-4 sentences.
TOP_K=6

# ★ Acme's OWN Supabase project (create it; run supabase/migration.sql)
SUPABASE_URL=https://acme-dev-xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-acme-dev-service-role
SUPABASE_ANON_KEY=eyJ-acme-dev-anon
SUPABASE_SCHEMA=public   # separate project → public is fine. Shared Nemo Supabase → use a dedicated schema (never public, Rule #12).

# Knowledge sources (POST /api/ingest)
DOCS_PATH=./docs
DOCS_BASE_URL=https://acme.com/docs
WEBSITE_URL=
WEBSITE_MAX_PAGES=60

# Abuse protection (Layers 1-3; Layer 4 = the key budget in Nemo)
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_IP_PER_MIN=20
RATE_LIMIT_PER_SESSION_PER_MIN=10
RATE_LIMIT_PER_IP_PER_DAY=500
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=

# ★ Admin token (gates /api/ingest AND the /admin config dashboard + PUT /api/config)
ADMIN_TOKEN=local-dev-token-change-me

# ─── Widget presentation (OPTIONAL) — defaults for /admin-editable settings ──────
# These seed the widget UI. The /admin dashboard overrides them at runtime (stored
# in your Supabase `agent_config` row) with NO redeploy. Leave unset to use the
# built-in defaults. Bad/dangerous hrefs (javascript:, data:) are dropped server-side.
#
# Suggestion chips — JSON array OR a comma-separated list.
SUGGESTIONS=["How does the platform fee work?","Which models are live today?","Is it OpenAI-compatible?","How is this different from OpenRouter?"]
# Quick links shown in the expanded rail — JSON array of {label, href}. Site-relative
# (/docs) or absolute https only.
QUICK_LINKS=[{"label":"Models","href":"/models"},{"label":"Pricing","href":"/pricing"},{"label":"Docs","href":"/docs"},{"label":"Playground","href":"/playground"}]
# Contact methods — JSON array of {type,label,value}. type ∈ phone | email | url.
# phone → tel:, email → mailto:, url → the href as-is.
CONTACT_METHODS=[{"type":"phone","label":"Call sales","value":"+1 (555) 010-2030"},{"type":"email","label":"Email support","value":"support@acme.com"},{"type":"url","label":"Contact us","value":"/contact"}]

# ─── Personalization (OPTIONAL) — "Hello <name>", account links, plan-scoped docs ─
# Pluggable login layer (lib/identity.ts). Leave IDENTITY_MODE=none to stay
# anonymous (default). Pick ONE mode + its vars; NO code changes needed.
#
#   none       → anonymous (default)
#   jwt        → verify a signed JWT in a cookie (set IDENTITY_JWT_SECRET + IDENTITY_COOKIE)
#   header     → trust a header from your auth proxy (oauth2-proxy / ALB OIDC / Cloudflare Access)
#   introspect → forward the visitor's cookies to YOUR existing "who am I" URL → it returns JSON
#   custom     → you write lib/identity.custom.ts exporting resolve(req, cfg)
IDENTITY_MODE=none

# jwt mode
IDENTITY_COOKIE=session
IDENTITY_JWT_SECRET=
# Claim→field mapping (works for jwt + introspect). attributes = extra claims to read.
IDENTITY_CLAIM_NAME=name
IDENTITY_CLAIM_ID=sub
IDENTITY_CLAIM_EMAIL=email
IDENTITY_CLAIM_ATTRIBUTES=org,plan

# header mode: trusted name header + "attrKey:header-name" attribute pairs
IDENTITY_HEADER=x-forwarded-user
IDENTITY_HEADER_ATTRIBUTES=org:x-forwarded-org,plan:x-forwarded-plan

# introspect mode: your app's session endpoint (receives the forwarded cookies)
IDENTITY_INTROSPECT_URL=

# Personalized links — JSON array; {attr} placeholders fill from the claims above.
# A link whose placeholder has no value is dropped (no broken links shown).
IDENTITY_LINKS=[{"label":"Your dashboard","url":"https://acme.com/app/{org}"},{"label":"Billing","url":"https://acme.com/app/{org}/billing"}]

# Greet signed-in users by name in the first reply ("Hello Guru"). Default true.
IDENTITY_GREET=true

# Which attribute becomes the extra doc-retrieval audience tag (needs the optional
# `audiences` column from supabase/migration.sql). e.g. plan=pro → docs tagged {public}|{pro}.
IDENTITY_DOC_AUDIENCE_ATTR=plan
