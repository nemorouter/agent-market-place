# ─── .env.local — LOCAL dev for Acme Inc ─────────────────────────────────────
# Copy to `.env.local` (gitignored) and fill the 4 ★ values, then: npm run dev
# Runs on http://localhost:3000 — Acme answers from its OWN Supabase KB.

CLOUD=local

# ★ Nemo Router (the brain). Create the key in the Nemo dashboard with a per-day
#   BUDGET + rate limit. SERVER-SIDE ONLY.
NEMOROUTER_API_KEY=sk-nemo-acme-local-xxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-005
GUARDRAILS=

# The agent
AGENT_ID=acme-support
AGENT_NAME=Acme Support
SYSTEM_PROMPT=You are Acme's support assistant. Answer ONLY from the provided context. If it isn't covered, say so and point the user to https://acme.com/support. Keep answers to 2-4 sentences.
TOP_K=6

# ★ Acme's OWN Supabase project (create it; run supabase/migration.sql)
SUPABASE_URL=https://acme-dev-xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-acme-dev-service-role
SUPABASE_ANON_KEY=eyJ-acme-dev-anon
SUPABASE_SCHEMA=public   # separate project → public is fine. Shared Nemo Supabase → use a dedicated schema (never public, Rule #12).

# Knowledge sources (POST /api/ingest)
DOCS_PATH=./docs
DOCS_BASE_URL=https://acme.com/docs
WEBSITE_URL=
WEBSITE_MAX_PAGES=60
# Crawl SSRF/DoS guards: the crawler only fetches PUBLIC http(s) hosts (private,
# loopback, link-local and cloud-metadata addresses are refused), never follows
# redirects, and caps each page's body + fetch time.
WEBSITE_FETCH_TIMEOUT_MS=10000
WEBSITE_MAX_PAGE_BYTES=2000000

# Abuse protection (Layers 1-3; Layer 4 = the key budget in Nemo)
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_IP_PER_MIN=20
RATE_LIMIT_PER_SESSION_PER_MIN=10
RATE_LIMIT_PER_IP_PER_DAY=500
CAPTCHA_ENABLED=false
# Only 'turnstile' is implemented; any other value FAILS CLOSED (every request is
# challenged) rather than silently passing — do not set it until that backend exists.
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=
# Number of TRUSTED reverse proxies in front of this app. Per-IP rate limits key off
# the proxy-appended X-Forwarded-For entry (`len - hops`), NOT the spoofable leftmost
# one. Cloud Run behind Google's LB = 1. Raise it if you add more proxies.
TRUSTED_PROXY_HOPS=1

# Inbound payload caps — DoS / cost-blowup protection. The chat route rejects
# oversized requests (413) BEFORE any model/embedding spend.
MAX_MESSAGES=60
MAX_MESSAGE_CHARS=12000
MAX_TOTAL_CHARS=60000

# ─── Distributed rate limit (PRODUCTION / multi-instance) ────────────────────────
# The in-memory limiter is per-instance — across N autoscaled Cloud Run instances
# the effective ceiling is N×. Set BOTH of these (Upstash Redis REST) and the
# RATE_LIMIT_* windows above become a SHARED limit across every instance. Unset →
# in-memory fallback (fine for a single instance / preview). A Redis outage also
# falls back to in-memory, so chat never goes down on the limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Upstream timeouts ───────────────────────────────────────────────────────────
# Cap how long a Nemo gateway call may hang before it's aborted, so a stuck upstream
# can't pin a serverless instance and exhaust the pool under load. Stream covers the
# full streamed answer; the unary value covers embeddings + tool-decision rounds.
NEMO_TIMEOUT_MS=30000
NEMO_STREAM_TIMEOUT_MS=120000
# Per-call timeout for the MCP tool gateway (list + execute). Without it a hung tool
# upstream would pin the instance — the chat route relies on this default.
NEMO_TOOL_TIMEOUT_MS=30000

# ─── /admin authentication ───────────────────────────────────────────────────
# Humans sign in to /admin with email OTP — SELF-CONTAINED (SendGrid + a signed
# challenge cookie). NO Supabase Auth, no auth.users, no DB table — fully isolated
# from Nemo user logins. Machines/scripts keep using ADMIN_TOKEN. Both are accepted
# by the admin API routes (lib/admin-auth.ts).
#
# Allowlist: only these emails can request/redeem a code. Comma list.
ADMIN_EMAILS=you@company.com
# Secret that signs the session + OTP-challenge cookies. 32+ random chars. REQUIRED.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SESSION_SECRET=
# SendGrid (sends the 6-digit code). Without these, OTP login can't email — use the token.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@nemorouter.ai
SENDGRID_FROM_NAME=Nemo Router
# ★ Admin token — break-glass + scripts/ingest.sh (machine-to-machine). Still valid.
ADMIN_TOKEN=local-dev-token-change-me

# ─── Widget presentation (OPTIONAL) — defaults for /admin-editable settings ──────
# These seed the widget UI. The /admin dashboard overrides them at runtime (stored
# in your Supabase `agent_config` row) with NO redeploy. Leave unset to use the
# built-in defaults. Bad/dangerous hrefs (javascript:, data:) are dropped server-side.
#
# Suggestion chips — JSON array OR a comma-separated list.
SUGGESTIONS=["How does the platform fee work?","Which models are live today?","Is it OpenAI-compatible?","How is this different from OpenRouter?"]
# Quick links shown in the expanded rail — JSON array of {label, href}. Site-relative
# (/docs) or absolute https only.
QUICK_LINKS=[{"label":"Models","href":"/models"},{"label":"Pricing","href":"/pricing"},{"label":"Docs","href":"/docs"},{"label":"Playground","href":"/playground"}]
# Contact methods — JSON array of {type,label,value}. type ∈ phone | email | url.
# phone → tel:, email → mailto:, url → the href as-is.
CONTACT_METHODS=[{"type":"phone","label":"Call sales","value":"+1 (555) 010-2030"},{"type":"email","label":"Email support","value":"support@acme.com"},{"type":"url","label":"Contact us","value":"/contact"}]

# ─── Tools (OPTIONAL) — Nemo MCP gateway (Phase 2) ───────────────────────────────
# Comma-separated gateway tool ids the agent may call. OFF by default (pure RAG).
# The /admin dashboard lists the tools your key can see (GET /v1/mcp/tools) and lets
# you toggle them — this is just the default seed. Each call is guardrailed,
# credit-metered, and audited server-side by the gateway. Unreachable gateway → the
# agent silently stays pure-RAG. Example: TOOLS_ENABLED=nemo_docs_search
TOOLS_ENABLED=

# ─── Web-search fallback (Phase 3) ───────────────────────────────────────────────
# When the knowledge base can't answer (low confidence) or the visitor clicks
# "Still not resolved? Search the web", the agent escalates to the gateway `web_search`
# tool (Google grounding or OpenAI web search, chosen server-side — see gateway env
# below). Fully graceful: if the tool isn't deployed/enabled it silently stays RAG-only.
WEB_SEARCH_ENABLED=true
# Auto-run web search when retrieval confidence is LOW (else only on explicit click).
WEB_SEARCH_AUTO_ON_LOW_CONFIDENCE=true
# Confidence thresholds on the top retrieved chunk's similarity (0..1):
#   topSimilarity >= CONFIDENCE_HIGH → "high"; < CONFIDENCE_LOW → "low" (triggers web search).
# Calibrated for text-embedding-005 (on-topic ~0.55-0.65, off-topic ~0.35).
CONFIDENCE_HIGH=0.55
CONFIDENCE_LOW=0.45
# NOTE: the web-search BACKEND is configured on the NEMO GATEWAY (nemo-backend), not here:
#   MCP_WEB_SEARCH_PROVIDER = auto | google | openai   (default: auto, inferred from model)
#   MCP_WEB_SEARCH_MODEL    = gemini-2.5-flash-lite (Google grounding, default)
#                             | gpt-5-search-api / gpt-4o-search-preview (OpenAI web search)

# ─── Tool credential vault (OPTIONAL) — agent-infra-only encryption ──────────────
# Lets the operator store a tool's secret (an API token) from /admin. The secret is
# sealed with AES-256-GCM using THIS key, which lives ONLY here — nemo-backend never
# holds it. Only this agent can decrypt; a DB dump alone is useless. At tool time the
# agent decrypts and passes the secret to the gateway for ONE transient call.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave unset to disable the vault (tools that need no credential still work).
TOOL_VAULT_KEY=

# ─── Personalization (OPTIONAL) — "Hello <name>", account links, plan-scoped docs ─
# Pluggable login layer (lib/identity.ts). Leave IDENTITY_MODE=none to stay
# anonymous (default). Pick ONE mode + its vars; NO code changes needed.
#
#   none       → anonymous (default)
#   jwt        → verify a signed JWT in a cookie (set IDENTITY_JWT_SECRET + IDENTITY_COOKIE)
#   header     → trust a header from your auth proxy (oauth2-proxy / ALB OIDC / Cloudflare Access)
#   introspect → forward the visitor's cookies to YOUR existing "who am I" URL → it returns JSON
#   custom     → you write lib/identity.custom.ts exporting resolve(req, cfg)
IDENTITY_MODE=none

# jwt mode
IDENTITY_COOKIE=session
IDENTITY_JWT_SECRET=
# Claim→field mapping (works for jwt + introspect). attributes = extra claims to read.
IDENTITY_CLAIM_NAME=name
IDENTITY_CLAIM_ID=sub
IDENTITY_CLAIM_EMAIL=email
IDENTITY_CLAIM_ATTRIBUTES=org,plan

# header mode: trusted name header + "attrKey:header-name" attribute pairs
IDENTITY_HEADER=x-forwarded-user
IDENTITY_HEADER_ATTRIBUTES=org:x-forwarded-org,plan:x-forwarded-plan

# introspect mode: your app's session endpoint (receives the forwarded cookies)
IDENTITY_INTROSPECT_URL=
# Timeout for the introspect call (resolved inline before the LLM call) so a slow
# session endpoint can't stall chat. Point IDENTITY_INTROSPECT_URL only at a host you control.
IDENTITY_INTROSPECT_TIMEOUT_MS=5000

# Personalized links — JSON array; {attr} placeholders fill from the claims above.
# A link whose placeholder has no value is dropped (no broken links shown).
IDENTITY_LINKS=[{"label":"Your dashboard","url":"https://acme.com/app/{org}"},{"label":"Billing","url":"https://acme.com/app/{org}/billing"}]

# Greet signed-in users by name in the first reply ("Hello Guru"). Default true.
IDENTITY_GREET=true

# Which attribute becomes the extra doc-retrieval audience tag (needs the optional
# `audiences` column from supabase/migration.sql). e.g. plan=pro → docs tagged {public}|{pro}.
IDENTITY_DOC_AUDIENCE_ATTR=plan
