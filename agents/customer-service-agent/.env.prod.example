# ─── .env.prod — PRODUCTION on Google Cloud Run ──────────────────────────────
# Copy to `.env.prod` (gitignored), fill values, then: npm run deploy:prod
#
# Tomorrow: set CLOUD=azure (or aws) once those paths land — same file, same flow.

CLOUD=gcp
GCP_PROJECT=acme-prod
GCP_REGION=us-central1
SERVICE_NAME=acme-support

# Nemo Router — PROD key with a per-day BUDGET (hard cap) + rate limit
NEMOROUTER_API_KEY=sk-nemo-acme-prod-xxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-3-small
GUARDRAILS=

# The agent
AGENT_ID=acme-support
AGENT_NAME=Acme Support
SYSTEM_PROMPT=You are Acme's support assistant. Answer ONLY from the provided context. If it isn't covered, say so and point the user to https://acme.com/support. Keep answers to 2-4 sentences.
TOP_K=6

# Acme's PROD Supabase project
SUPABASE_URL=https://acme-prod-xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-acme-prod-service-role
SUPABASE_ANON_KEY=eyJ-acme-prod-anon

# Knowledge sources
DOCS_PATH=./docs
DOCS_BASE_URL=https://acme.com/docs
WEBSITE_URL=https://acme.com/docs
WEBSITE_MAX_PAGES=120

# Abuse protection
ALLOWED_ORIGINS=https://acme.com,https://*.acme.com
RATE_LIMIT_PER_IP_PER_MIN=30
RATE_LIMIT_PER_SESSION_PER_MIN=12
RATE_LIMIT_PER_IP_PER_DAY=800
CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=set-your-turnstile-secret

ADMIN_TOKEN=set-a-long-random-prod-token
