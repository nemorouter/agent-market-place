# ─── .env.stage — STAGE on Google Cloud Run ──────────────────────────────────
# Copy to `.env.stage` (gitignored), fill values, then: npm run deploy:stage

CLOUD=gcp
GCP_PROJECT=acme-staging
GCP_REGION=us-central1
SERVICE_NAME=acme-support-stage

# Nemo Router
NEMOROUTER_API_KEY=sk-nemo-acme-stage-xxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-3-small
GUARDRAILS=

# The agent
AGENT_ID=acme-support
AGENT_NAME=Acme Support (stage)
SYSTEM_PROMPT=You are Acme's support assistant. Answer ONLY from the provided context. If it isn't covered, say so and point the user to https://acme.com/support. Keep answers to 2-4 sentences.
TOP_K=6

# Acme's STAGE Supabase project
SUPABASE_URL=https://acme-stage-xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-acme-stage-service-role
SUPABASE_ANON_KEY=eyJ-acme-stage-anon
SUPABASE_SCHEMA=public

# Knowledge sources
DOCS_PATH=./docs
DOCS_BASE_URL=https://staging.acme.com/docs
WEBSITE_URL=https://staging.acme.com/docs
WEBSITE_MAX_PAGES=60

# Abuse protection
ALLOWED_ORIGINS=https://staging.acme.com,https://*.staging.acme.com
RATE_LIMIT_PER_IP_PER_MIN=20
RATE_LIMIT_PER_SESSION_PER_MIN=10
RATE_LIMIT_PER_IP_PER_DAY=500
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=

ADMIN_TOKEN=stage-token-change-me
