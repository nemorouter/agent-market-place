# ─── .env.local — Nemo Support agent, LOCAL ──────────────────────────────────
# Run with the ../customer-service-agent app:
#   cd ../customer-service-agent
#   cp ../nemo-support-agent/.env.local.example .env.local   # then fill ★
#   cp -r ../nemo-support-agent/docs/* ./docs/               # nemo support docs
#   npm run dev && npm run ingest

CLOUD=local

# ★ Nemo Router key (platform support agent). Server-side only; give it a budget.
NEMOROUTER_API_KEY=sk-nemo-support-local-xxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-3-small
GUARDRAILS=

AGENT_ID=nemo-support
AGENT_NAME=Nemo Support
SYSTEM_PROMPT=You are the Nemo Router support assistant. Answer ONLY from the provided context. If it isn't covered, point the user to https://nemorouter.ai/docs or support@nemorouter.ai. Never invent pricing or limits. Keep answers concise.
TOP_K=6

# ★ EXISTING Nemo Supabase project (NOT a new project) + the new schema "nemo_amp_db".
#   Run supabase/migration.sql in that project, then expose nemo_amp_db to PostgREST.
SUPABASE_URL=https://your-existing-nemo-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-existing-nemo-service-role
SUPABASE_ANON_KEY=eyJ-existing-nemo-anon
SUPABASE_SCHEMA=nemo_amp_db

DOCS_PATH=./docs
DOCS_BASE_URL=https://nemorouter.ai/docs
WEBSITE_URL=
WEBSITE_MAX_PAGES=120

ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_IP_PER_MIN=30
RATE_LIMIT_PER_SESSION_PER_MIN=12
RATE_LIMIT_PER_IP_PER_DAY=800
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=

ADMIN_TOKEN=local-dev-token-change-me
