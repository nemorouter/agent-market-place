# ─── .env.prod — Nemo Support agent, PRODUCTION on Google Cloud Run ──────────
# Replaces the legacy support agent. Same one-command deploy as any agent:
#   (from ../customer-service-agent, with this env + docs)  npm run deploy:prod

CLOUD=gcp
GCP_PROJECT=nemo-prod-deploy
GCP_REGION=us-central1
SERVICE_NAME=nemo-support-agent

# Nemo Router — prod platform key with a per-day BUDGET (hard cap) + rate limit
NEMOROUTER_API_KEY=sk-nemo-support-prod-xxxxxxxx
NEMO_BASE_URL=https://api.nemorouter.ai
MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=text-embedding-005
GUARDRAILS=

AGENT_ID=nemo-support
AGENT_NAME=Nemo Support
SYSTEM_PROMPT=You are the Nemo Router support assistant. Answer ONLY from the provided context. If it isn't covered, point the user to https://nemorouter.ai/docs or support@nemorouter.ai. Never invent pricing or limits. Keep answers concise.
TOP_K=6

# EXISTING Nemo Supabase (prod) + the nemo_amp_db schema
SUPABASE_URL=https://your-existing-nemo-prod-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-existing-nemo-prod-service-role
SUPABASE_ANON_KEY=eyJ-existing-nemo-prod-anon
SUPABASE_SCHEMA=nemo_amp_db

DOCS_PATH=./docs
DOCS_BASE_URL=https://nemorouter.ai/docs
WEBSITE_URL=https://nemorouter.ai/docs
WEBSITE_MAX_PAGES=200

ALLOWED_ORIGINS=https://nemorouter.ai,https://*.nemorouter.ai
RATE_LIMIT_PER_IP_PER_MIN=30
RATE_LIMIT_PER_SESSION_PER_MIN=12
RATE_LIMIT_PER_IP_PER_DAY=800
CAPTCHA_ENABLED=true
CAPTCHA_PROVIDER=turnstile
CAPTCHA_TRIGGER=after_3_messages
CAPTCHA_SECRET_KEY=set-your-turnstile-secret

ADMIN_TOKEN=set-a-long-random-prod-token
